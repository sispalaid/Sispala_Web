# ==============================================================================
# SISPALA WEB CCTV ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# Copy this file to .env and fill in your actual credentials/configurations.
# DO NOT commit the actual .env file to Git!
# ==============================================================================

# Node.js Express Session Security Secret
SESSION_SECRET=your-secret-session-key-change-this-in-production

# Default Superadmin Account Credentials (used on clean startup if users.json is missing)
DEFAULT_ADMIN_USER=superadmin
DEFAULT_ADMIN_PASSWORD=your-super-secure-default-password-change-this

# Camera 1 Configuration
# ------------------------------------------------------------------------------
# RTSP stream URL of the physical camera
CAM1_RTSP_URL=rtsp://admin:password@192.168.0.x:554/stream1
# Path to the compiled YOLO TensorRT engine
CAM1_MODEL_PATH=/home/sispala/yolo26n.engine
# Device to run YOLO inference on ('cpu', 'cuda:0', etc.)
CAM1_DEVICE=cuda:0
# Target video encoding bitrate for HLS and MP4 recordings (e.g. 1.5M, 1500k)
CAM1_BITRATE=1.5M
# Timeout in seconds to wait for RTSP packets before declaring connection loss
CAM1_TIMEOUT=15
# RTSP transport from server to local proxy ('tcp' or 'udp')
# Hint: Use 'udp' on high-jitter/unstable connections to prevent stream freezes
CAM1_RTSP_TRANSPORT=tcp
# Enable/disable camera audio recording ('on' or 'off')
CAM1_AUDIO=off
# RTSP protocol from MediaMTX to physical camera ('automatic', 'tcp', 'udp', 'multicast')
CAM1_PROXY_SOURCE_PROTOCOL=automatic
# Set to 'yes' to only connect to camera when a local client is watching (saves camera bandwidth)
CAM1_PROXY_ON_DEMAND=no
# If on-demand is 'yes', delay before closing physical connection after client exits
CAM1_PROXY_ON_DEMAND_CLOSE_AFTER=10s
# Reconnection delay for MediaMTX to reconnect to the physical camera (e.g. 5s, 10s)
CAM1_PROXY_RECONNECT_DELAY=10s

# Camera 2 Configuration
# ------------------------------------------------------------------------------
CAM2_RTSP_URL=rtsp://admin:password@192.168.0.x:554/stream1
CAM2_MODEL_PATH=/home/sispala/yolo26n.engine
CAM2_DEVICE=cuda:0
CAM2_BITRATE=1.5M
CAM2_TIMEOUT=15
CAM2_RTSP_TRANSPORT=tcp
CAM2_AUDIO=off
CAM2_PROXY_SOURCE_PROTOCOL=automatic
CAM2_PROXY_ON_DEMAND=no
CAM2_PROXY_ON_DEMAND_CLOSE_AFTER=10s
CAM2_PROXY_RECONNECT_DELAY=10s

# Camera 3 Configuration
# ------------------------------------------------------------------------------
CAM3_RTSP_URL=rtsp://admin:password@192.168.0.x:554/stream1
CAM3_MODEL_PATH=/home/sispala/yolo26n.engine
CAM3_DEVICE=cuda:0
CAM3_BITRATE=1.5M
CAM3_TIMEOUT=15
CAM3_RTSP_TRANSPORT=tcp
CAM3_AUDIO=off
CAM3_PROXY_SOURCE_PROTOCOL=automatic
CAM3_PROXY_ON_DEMAND=no
CAM3_PROXY_ON_DEMAND_CLOSE_AFTER=10s
CAM3_PROXY_RECONNECT_DELAY=10s

# Camera 4 Configuration
# ------------------------------------------------------------------------------
CAM4_RTSP_URL=rtsp://admin:password@192.168.0.x:554/stream1
CAM4_MODEL_PATH=/home/sispala/yolo26n.engine
CAM4_DEVICE=cuda:0
CAM4_BITRATE=1.5M
CAM4_TIMEOUT=15
CAM4_RTSP_TRANSPORT=tcp
CAM4_AUDIO=off
CAM4_PROXY_SOURCE_PROTOCOL=automatic
CAM4_PROXY_ON_DEMAND=no
CAM4_PROXY_ON_DEMAND_CLOSE_AFTER=10s
CAM4_PROXY_RECONNECT_DELAY=10s
